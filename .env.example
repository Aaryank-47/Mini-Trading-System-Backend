# Trading Platform API - Environment Variables Example
# Copy this file to .env and fill in with your actual values
# NEVER commit .env to Git!

# Application
ENVIRONMENT=LOCAL
DEBUG=False

# Security (Change these for production!)
SECRET_KEY=your-super-secret-key-here-min-32-characters

# MySQL Database Configuration
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=trading_db

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# For Production Deployment (Render/Railway/etc):
# Example for Render MySQL:
# MYSQL_HOST=your-render-mysql-host.c.aivencloud.com
# MYSQL_USER=avnadmin
# MYSQL_PASSWORD=your-secure-password
# MYSQL_DATABASE=defaultdb

# Example for Render Redis:
# REDIS_URL=redis://:your-password@your-render-redis-host:12345
